{
  "id": "ai-dossier-intake",
  "version": 2,
  "title": "Publication Setup",
  "steps": [
    {
      "id": "your-publication",
      "title": "Your Publication",
      "description": "The basics: what is your publication, who reads it, and what lens do you apply to every story?",
      "sections": [
        {
          "id": "identity",
          "label": "Identity",
          "fields": ["publication_name", "tagline", "full_title", "topic_label"]
        },
        {
          "id": "where-it-lives",
          "label": "Where It Lives",
          "fields": ["site_url", "publisher_name", "publisher_url"]
        },
        {
          "id": "audience",
          "label": "Your Audience",
          "fields": ["audience_description", "key_question", "reader_profile"]
        },
        {
          "id": "derived-labels",
          "label": "Derived Labels",
          "collapsible": true,
          "defaultOpen": false,
          "fields": ["publication_type", "community_label"]
        }
      ],
      "fields": [
        {
          "id": "publication_name",
          "type": "text",
          "label": "Publication Name",
          "help": "Appears in header, browser tab, and social cards.",
          "placeholder": "CLIMATE DOSSIER",
          "validation": {
            "required": true,
            "maxLength": 100
          }
        },
        {
          "id": "tagline",
          "type": "text",
          "label": "Tagline",
          "help": "One line for search results and social shares.",
          "placeholder": "Daily intelligence on climate policy and governance",
          "validation": {
            "required": true,
            "maxLength": 150
          }
        },
        {
          "id": "full_title",
          "type": "text",
          "label": "Full Title",
          "help": "Auto-filled from name + tagline. Edit if you want something different.",
          "placeholder": "CLIMATE DOSSIER — Daily Climate Policy Briefing",
          "validation": {
            "required": true,
            "maxLength": 200
          }
        },
        {
          "id": "topic_label",
          "type": "text",
          "label": "Topic Label",
          "help": "2\u20134 words. Used throughout the pipeline.",
          "placeholder": "climate policy",
          "validation": {
            "required": true,
            "maxLength": 50
          }
        },
        {
          "id": "site_url",
          "type": "url",
          "label": "Site URL",
          "help": "Where your site will live.",
          "placeholder": "https://climatedossier.org",
          "validation": {
            "required": true
          }
        },
        {
          "id": "publisher_name",
          "type": "text",
          "label": "Publisher Name",
          "help": "Your organization or company name.",
          "placeholder": "Climate Action Network",
          "validation": {
            "required": true,
            "maxLength": 100
          }
        },
        {
          "id": "publisher_url",
          "type": "url",
          "label": "Publisher URL",
          "help": "Your organization's website.",
          "placeholder": "https://climatenetwork.org",
          "validation": {
            "required": true
          }
        },
        {
          "id": "audience_description",
          "type": "text",
          "label": "Who Reads This?",
          "help": "2\u20134 reader types, comma-separated.",
          "placeholder": "policy advisors, journalists, analysts",
          "validation": {
            "required": true,
            "maxLength": 300
          }
        },
        {
          "id": "key_question",
          "type": "textarea",
          "rows": 5,
          "label": "Key Question",
          "help": "The single question every story is evaluated against. Shapes how importance is scored.",
          "placeholder": "How does this affect the trajectory of global decarbonization?",
          "validation": {
            "required": true,
            "maxLength": 500
          }
        },
        {
          "id": "reader_profile",
          "type": "textarea",
          "rows": 6,
          "label": "Reader Profile",
          "help": "3\u20135 sentences: who are they, what\u2019s their expertise, what should they take away? Write as \u201cYou are writing for\u2026\u201d",
          "placeholder": "You are writing for smart professionals who follow climate policy but are not scientists\u2026",
          "validation": {
            "required": true,
            "maxLength": 1000
          }
        },
        {
          "id": "publication_type",
          "type": "text",
          "label": "Publication Type",
          "help": "Auto-filled from your topic. A sentence fragment describing the publication.",
          "placeholder": "climate policy intelligence briefing",
          "validation": {
            "required": false,
            "maxLength": 150
          }
        },
        {
          "id": "community_label",
          "type": "text",
          "label": "Community Label",
          "help": "Auto-filled. What you call your reader community.",
          "placeholder": "the climate policy community",
          "validation": {
            "required": false,
            "maxLength": 100
          }
        }
      ]
    },
    {
      "id": "categories-and-editors",
      "title": "Categories & Editors",
      "description": "Define your categories, then customize the AI editors that review every story through their domain lens. Editors are auto-generated from your categories.",
      "sections": [
        {
          "id": "categories-section",
          "label": "Categories",
          "fields": ["categories"]
        },
        {
          "id": "editors-section",
          "label": "Editorial Team",
          "fields": ["editors"]
        }
      ],
      "fields": [
        {
          "id": "categories",
          "type": "repeating",
          "label": "Categories",
          "help": "Each category becomes a filter button on your site.",
          "showColorDots": true,
          "validation": {
            "required": true,
            "minItems": 3
          },
          "fields": [
            {
              "id": "short_label",
              "type": "text",
              "label": "Short Label",
              "help": "For the filter button. E.g. \u201cPolicy\u201d, \u201cFinance\u201d",
              "placeholder": "Policy",
              "validation": {
                "required": true,
                "maxLength": 30
              }
            },
            {
              "id": "full_name",
              "type": "text",
              "label": "Full Name",
              "help": "E.g. \u201cClimate Policy & Governance\u201d",
              "placeholder": "Climate Policy & Governance",
              "validation": {
                "required": true,
                "maxLength": 100
              }
            },
            {
              "id": "auto_tags",
              "type": "text",
              "label": "Auto-Tags",
              "help": "Keywords for sorting stories into this category. At least 2, comma-separated.",
              "placeholder": "governance, regulation, legislation",
              "validation": {
                "required": true,
                "minLength": 3,
                "maxLength": 300,
                "pattern": "^[a-zA-Z0-9\\-\\s,]*$"
              }
            }
          ]
        },
        {
          "id": "editors",
          "type": "repeating",
          "label": "Editors",
          "help": "One editor per category, plus a Spotlight editor. Pre-filled from your categories \u2014 add expertise descriptions.",
          "validation": {
            "required": true,
            "minItems": 3
          },
          "autoPopulateFromCategories": true,
          "fields": [
            {
              "id": "editor_name",
              "type": "text",
              "label": "Editor Name",
              "help": "E.g. \u201cPolicy Editor\u201d, \u201cSpotlight Editor\u201d",
              "placeholder": "Policy Editor",
              "validation": {
                "required": true,
                "maxLength": 50
              }
            },
            {
              "id": "category",
              "type": "text",
              "label": "Category",
              "help": "Which category does this editor cover? Each category can only be assigned to one editor.",
              "placeholder": "policy",
              "validation": {
                "required": true,
                "maxLength": 30,
                "pattern": "^[a-zA-Z0-9\\-\\s]+$"
              }
            },
            {
              "id": "is_spotlight",
              "type": "checkbox",
              "label": "Is Spotlight Editor",
              "help": "The Spotlight editor finds podcasts, videos, demos, and other non-news content.",
              "validation": {
                "required": false
              }
            },
            {
              "id": "expertise",
              "type": "textarea",
              "label": "Expertise",
              "help": "1\u20132 paragraphs: who they are, what sub-areas they cover, and what they notice that generalists miss. The more specific, the sharper the reviews.",
              "placeholder": "You are the Policy Editor \u2014 an expert in\u2026",
              "validation": {
                "required": true,
                "maxLength": 2000
              }
            }
          ]
        }
      ]
    },
    {
      "id": "sentiment-and-scoring",
      "title": "Sentiment & Scoring",
      "description": "Configure your sentiment tracker \u2014 a metric that measures whether things in your domain are getting better or worse over time.",
      "sections": [
        {
          "id": "tracker-config",
          "label": "Tracker Configuration",
          "fields": ["tracker_name", "tracker_subtitle", "tracker_nav_label", "positive_signal_label", "negative_signal_label"]
        },
        {
          "id": "signal-meanings",
          "label": "What Your Signals Mean",
          "fields": ["what_positive_means", "what_negative_means", "fallback_sentiment_question"]
        },
        {
          "id": "scoring-calibration",
          "label": "Scoring Calibration",
          "collapsible": true,
          "defaultOpen": false,
          "fields": ["scoring_positive", "scoring_negative", "scoring_neutral"]
        },
        {
          "id": "per-category-rules",
          "label": "Per-Category Rules",
          "collapsible": true,
          "defaultOpen": false,
          "optional": {
            "label": "I don\u2019t need custom sentiment rules",
            "consequences": "Without custom rules, the pipeline uses general-purpose sentiment analysis. It works well for obvious cases but may misjudge domain-specific signals."
          },
          "fields": ["sentiment_rules_by_category"]
        },
        {
          "id": "tracker-advanced",
          "label": "Advanced",
          "collapsible": true,
          "defaultOpen": false,
          "fields": ["tracker_concept_url"]
        }
      ],
      "fields": [
        {
          "id": "tracker_name",
          "type": "text",
          "label": "Tracker Name",
          "help": "Appears in navigation and charts. Auto-filled from your topic.",
          "placeholder": "Climate Risk Index",
          "validation": {
            "required": true,
            "maxLength": 50
          }
        },
        {
          "id": "tracker_subtitle",
          "type": "text",
          "label": "Tracker Subtitle",
          "help": "Longer name for page titles and metadata.",
          "placeholder": "Climate Policy Sentiment Index",
          "validation": {
            "required": true,
            "maxLength": 100
          }
        },
        {
          "id": "tracker_nav_label",
          "type": "text",
          "label": "Navigation Label",
          "help": "Navigation tab label. E.g. \u201cTracker\u201d, \u201cPulse\u201d",
          "placeholder": "Tracker",
          "validation": {
            "required": true,
            "maxLength": 30
          }
        },
        {
          "id": "positive_signal_label",
          "type": "text",
          "label": "Positive Signal Label",
          "help": "Shows next to positive stories. E.g. \u201cprogress points\u201d",
          "placeholder": "progress points",
          "validation": {
            "required": true,
            "maxLength": 50
          }
        },
        {
          "id": "negative_signal_label",
          "type": "text",
          "label": "Negative Signal Label",
          "help": "Shows next to negative stories. E.g. \u201crisk points\u201d",
          "placeholder": "risk points",
          "validation": {
            "required": true,
            "maxLength": 50
          }
        },
        {
          "id": "what_positive_means",
          "type": "textarea",
          "rows": 3,
          "label": "What Positive Means",
          "help": "One sentence: what does a positive signal mean in your domain?",
          "placeholder": "Things are improving because\u2026",
          "validation": {
            "required": true,
            "maxLength": 500
          }
        },
        {
          "id": "what_negative_means",
          "type": "textarea",
          "rows": 3,
          "label": "What Negative Means",
          "help": "One sentence: what does a negative signal mean?",
          "placeholder": "Things are getting worse because\u2026",
          "validation": {
            "required": true,
            "maxLength": 500
          }
        },
        {
          "id": "fallback_sentiment_question",
          "type": "textarea",
          "rows": 3,
          "label": "Fallback Question",
          "help": "Tiebreaker when sentiment isn\u2019t obvious. Frame as a yes/no question about direction.",
          "placeholder": "Is the situation getting better or worse?",
          "validation": {
            "required": true,
            "maxLength": 500
          }
        },
        {
          "id": "scoring_positive",
          "type": "textarea",
          "rows": 4,
          "label": "Positive Scoring",
          "help": "2\u20133 concrete examples of stories your audience would instantly recognize as good news.",
          "placeholder": "A story is positive when\u2026",
          "validation": {
            "required": true,
            "maxLength": 1000
          }
        },
        {
          "id": "scoring_negative",
          "type": "textarea",
          "rows": 4,
          "label": "Negative Scoring",
          "help": "2\u20133 concrete examples of stories your audience would recognize as bad news.",
          "placeholder": "A story is negative when\u2026",
          "validation": {
            "required": true,
            "maxLength": 1000
          }
        },
        {
          "id": "scoring_neutral",
          "type": "textarea",
          "rows": 4,
          "label": "Neutral Scoring",
          "help": "2\u20133 examples of stories that are neither clearly positive nor negative.",
          "placeholder": "A story is neutral when\u2026",
          "validation": {
            "required": true,
            "maxLength": 1000
          }
        },
        {
          "id": "sentiment_rules_by_category",
          "type": "custom",
          "label": "Sentiment Rules",
          "help": "Focus on non-obvious cases \u2014 the pipeline already gets obvious ones right.",
          "validation": {
            "required": false
          }
        },
        {
          "id": "tracker_concept_url",
          "type": "url",
          "label": "Tracker Concept URL",
          "help": "Optional link explaining your metric concept.",
          "placeholder": "https://en.wikipedia.org/wiki/\u2026",
          "validation": {
            "required": false
          }
        }
      ]
    },
    {
      "id": "sources-and-discovery",
      "title": "Sources & Discovery",
      "description": "RSS feeds your publication monitors daily, plus optional social profiles and key organizations for scoring.",
      "sections": [
        {
          "id": "rss-sources",
          "label": "RSS Sources",
          "fields": ["sources"]
        },
        {
          "id": "social-profiles",
          "label": "Social Profiles",
          "collapsible": true,
          "defaultOpen": false,
          "optional": {
            "label": "I don\u2019t need social monitoring",
            "consequences": "Without social profiles, the pipeline won\u2019t track community discussion or include social signals in story scoring."
          },
          "fields": ["bluesky_handles", "x_handles", "linkedin_urls"]
        },
        {
          "id": "key-organizations",
          "label": "Key Organizations",
          "collapsible": true,
          "defaultOpen": false,
          "optional": {
            "label": "I\u2019ll add organizations later",
            "consequences": "Without key organizations, stories won\u2019t get score bonuses for mentioning important players."
          },
          "fields": ["key_organizations"]
        },
        {
          "id": "triage-topics",
          "label": "Triage Topics",
          "collapsible": true,
          "defaultOpen": false,
          "optional": {
            "label": "I\u2019ll add triage topics later",
            "consequences": "Without triage topics, the pipeline uses your categories and key question for filtering, which works but is less precise."
          },
          "fields": ["triage_topics"]
        }
      ],
      "fields": [
        {
          "id": "sources",
          "type": "repeating",
          "label": "RSS Sources",
          "help": "Verify a feed by visiting the URL \u2014 it should show XML.",
          "validation": {
            "required": true,
            "minItems": 1
          },
          "batchInput": {
            "enabled": true,
            "csvColumns": ["name", "url", "tags", "notes"],
            "jsonExample": "{\"name\": \"Carbon Brief\", \"url\": \"https://www.carbonbrief.org/feed\", \"tags\": \"policy, science\", \"notes\": \"UK-based climate science and policy analysis\"}"
          },
          "fields": [
            {
              "id": "name",
              "type": "text",
              "label": "Source Name",
              "placeholder": "Carbon Brief",
              "validation": {
                "required": true,
                "maxLength": 100
              }
            },
            {
              "id": "tags",
              "type": "text",
              "label": "Tags",
              "help": "Comma-separated category labels.",
              "placeholder": "policy, science",
              "validation": {
                "required": true,
                "maxLength": 200,
                "pattern": "^[a-zA-Z0-9\\-\\s,]*$"
              }
            },
            {
              "id": "url",
              "type": "url",
              "label": "Feed URL",
              "help": "Try /feed, /rss, or /feed.xml on the site.",
              "placeholder": "https://example.com/feed",
              "validation": {
                "required": true
              }
            },
            {
              "id": "notes",
              "type": "textarea",
              "label": "Notes",
              "rows": 2,
              "help": "For your reference only.",
              "placeholder": "Optional notes\u2026",
              "validation": {
                "required": false,
                "maxLength": 500
              }
            }
          ]
        },
        {
          "id": "bluesky_handles",
          "type": "repeating",
          "label": "Bluesky Handles",
          "help": "Key researchers, journalists, and advocates on Bluesky.",
          "validation": {
            "required": false,
            "minItems": 0
          },
          "batchInput": {
            "enabled": true,
            "csvColumns": ["handle"]
          },
          "fields": [
            {
              "id": "handle",
              "type": "text",
              "label": "Bluesky Handle",
              "help": "E.g. \u201cclimatescientist.bsky.social\u201d",
              "placeholder": "username.bsky.social",
              "validation": {
                "required": false,
                "maxLength": 100,
                "pattern": "^[a-zA-Z0-9][a-zA-Z0-9.-]*\\.[a-zA-Z]{2,}$"
              }
            }
          ]
        },
        {
          "id": "x_handles",
          "type": "repeating",
          "label": "X.com Handles",
          "help": "Key voices on X (formerly Twitter).",
          "validation": {
            "required": false,
            "minItems": 0
          },
          "batchInput": {
            "enabled": true,
            "csvColumns": ["handle"]
          },
          "fields": [
            {
              "id": "handle",
              "type": "text",
              "label": "X Handle",
              "help": "1\u201315 characters. E.g. \u201c@climatejournalist\u201d",
              "placeholder": "@username",
              "validation": {
                "required": false,
                "maxLength": 16,
                "pattern": "^@?[a-zA-Z0-9_]{1,15}$"
              }
            }
          ]
        },
        {
          "id": "linkedin_urls",
          "type": "repeating",
          "label": "LinkedIn Profiles",
          "help": "Key voices in your field on LinkedIn.",
          "validation": {
            "required": false,
            "minItems": 0
          },
          "batchInput": {
            "enabled": true,
            "csvColumns": ["url"]
          },
          "fields": [
            {
              "id": "url",
              "type": "url",
              "label": "LinkedIn URL",
              "help": "Full profile URL.",
              "placeholder": "https://linkedin.com/in/\u2026",
              "validation": {
                "required": false
              }
            }
          ]
        },
        {
          "id": "key_organizations",
          "type": "repeating",
          "label": "Key Organizations",
          "help": "Stories mentioning these get a score bonus. List 10\u201315. If everything gets a bonus, nothing does.",
          "validation": {
            "required": false,
            "minItems": 0
          },
          "batchInput": {
            "enabled": true,
            "csvColumns": ["name"]
          },
          "fields": [
            {
              "id": "name",
              "type": "text",
              "label": "Organization Name",
              "help": "Full name. E.g. \u201cInternational Energy Agency\u201d",
              "placeholder": "Organization name",
              "validation": {
                "required": false,
                "maxLength": 200
              }
            }
          ]
        },
        {
          "id": "triage_topics",
          "type": "repeating",
          "label": "Triage Topics",
          "help": "First filter \u2014 anything not matching gets discarded. Be generous. Aim for 4\u20136.",
          "validation": {
            "required": false,
            "minItems": 0
          },
          "batchInput": {
            "enabled": true,
            "csvColumns": ["topic"]
          },
          "fields": [
            {
              "id": "topic",
              "type": "text",
              "label": "Topic",
              "help": "Short phrase. E.g. \u201cClimate litigation and legal precedents\u201d",
              "placeholder": "Topic area\u2026",
              "validation": {
                "required": false,
                "maxLength": 200
              }
            }
          ]
        }
      ]
    },
    {
      "id": "review-and-launch",
      "title": "Review & Launch",
      "description": "Write your About page content, review your setup, and launch.",
      "sections": [
        {
          "id": "about-page",
          "label": "About Page",
          "collapsible": true,
          "defaultOpen": true,
          "optional": {
            "label": "I\u2019ll write the about page later",
            "consequences": "Without about page content, we\u2019ll generate placeholder text based on your other answers."
          },
          "fields": ["about_what_is_this", "about_tracker", "about_built_by"]
        },
        {
          "id": "technical-details",
          "label": "Technical Details",
          "collapsible": true,
          "defaultOpen": false,
          "fields": ["llms_description"]
        }
      ],
      "fields": [
        {
          "id": "about_what_is_this",
          "type": "textarea",
          "rows": 5,
          "label": "What Is This?",
          "help": "2\u20133 sentences for a first-time visitor.",
          "placeholder": "This publication is\u2026",
          "validation": {
            "required": true,
            "maxLength": 1000
          }
        },
        {
          "id": "about_tracker",
          "type": "textarea",
          "rows": 4,
          "label": "About the Tracker",
          "help": "What your tracker measures and why it matters. 2\u20133 sentences.",
          "placeholder": "The tracker measures\u2026",
          "validation": {
            "required": true,
            "maxLength": 1000
          }
        },
        {
          "id": "about_built_by",
          "type": "textarea",
          "rows": 3,
          "label": "Built By",
          "help": "1\u20132 sentences. Who are you and why did you build this?",
          "placeholder": "Built by\u2026",
          "validation": {
            "required": true,
            "maxLength": 500
          }
        },
        {
          "id": "llms_description",
          "type": "textarea",
          "rows": 2,
          "label": "LLMs Description",
          "help": "One sentence for AI crawlers (llms.txt). Auto-filled from your tagline.",
          "placeholder": "Daily intelligence briefing on\u2026",
          "validation": {
            "required": false,
            "maxLength": 300
          }
        }
      ]
    }
  ]
}
